# App
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://oqjf:oqjf@localhost:5432/oqjf

# Redis
REDIS_URL=redis://localhost:6379

# WhatsApp Business API (Meta Cloud API)
META_VERIFY_TOKEN=my-verify-token-local
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-access-token
META_PHONE_NUMBER_ID=your-phone-number-id

# Google Gemini (billing ATIVO obrigatório em produção)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_PRIMARY_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=500
GEMINI_TEMPERATURE=0.85
GEMINI_DAILY_BUDGET_USD_CENTS=500

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_ID=price_placeholder
CHECKOUT_SUCCESS_URL=http://localhost:3000/billing/success
CHECKOUT_CANCEL_URL=https://wa.me/SEU_NUMERO

# Freemium
FREE_MESSAGES_LIMIT=30

# Safety (DEVE ser true em produção — app não sobe se false em prod)
SAFETY_MODULE_ENABLED=true
CVV_NUMBER=188

# Alertas
